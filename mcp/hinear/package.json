{
  "name": "@hinear/mcp",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "bin": {
    "hinear-mcp": "./src/index.js"
  },
  "files": [
    "src",
    "scripts"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsx scripts/smoke.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@octokit/rest": "^22.0.1",
    "@supabase/supabase-js": "^2.99.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "description": "Hinear MCP Server - Issue management integration for AI agents",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "issue-tracker",
    "hinear"
  ],
  "author": "Hinear",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/choiho/hinear.git",
    "directory": "mcp/hinear"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
